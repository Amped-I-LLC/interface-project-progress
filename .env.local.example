# ============================================================
# Amped I Interface Template — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.
# ============================================================

# Supabase — get these from your Supabase project settings
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key — SERVER ONLY
# Used by app/api/airtable/route.js to read the airtable_keys table.
# Get from Supabase Dashboard → Project Settings → API → service_role key
#
# SECURITY RULES:
# - NEVER add NEXT_PUBLIC_ prefix — this key must stay server-side
# - NEVER log this key in console.log or any logging
# - NEVER import or reference it in any 'use client' component
# - NEVER commit the actual value to GitHub
# - Only used in app/api/ server routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Identity — used by proxy.js for portal access enforcement
# Set to the exact GitHub repo name for this interface (e.g. interface-sales-dashboard).
# proxy.js matches this against portal_apps.github_repo to verify
# the logged-in user has a portal_user_app_access row for this app.
# Leave blank only if this interface is intentionally NOT listed in the App Portal.
NEXT_PUBLIC_APP_NAME=interface-your-app-name

# App Portal URL — used by proxy.js to redirect unauthorized users
# Only change this if the portal moves to a different domain.
NEXT_PUBLIC_PORTAL_URL=https://portal.amped-i.com

# Note: Airtable API keys are NOT stored here.
# They are stored in the Supabase `airtable_keys` table,
# protected by RLS, and fetched server-side at runtime.
# See app/api/airtable/route.js for the pattern.
